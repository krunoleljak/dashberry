{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Dev Mode (Hot Reload)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "/home/kruno/.nvm/versions/node/v22.12.0/bin/npm",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "ELECTRON_RUN_AS_NODE": ""
            }
        },
        {
            // Use IntelliSense to find out which attributes exist for C# debugging
            // Use hover for the description of the existing attributes
            // For further information visit https://github.com/dotnet/vscode-csharp/blob/main/debugger-launchjson.md.
            "name": ".NET Core Launch (web)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            // If you have changed target frameworks, make sure to update the program path.
            "program": "${workspaceFolder}/backend/bin/Debug/net9.0/backend.dll",
            "args": [],
            "cwd": "${workspaceFolder}/backend",
            "stopAtEntry": false,
            // Enable launching a web browser when ASP.NET Core starts. For more information: https://aka.ms/VSCode-CS-LaunchJson-WebBrowser
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        },
        {
            "name": "Package Linux x64",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "/home/kruno/.nvm/versions/node/v22.12.0/bin/npm",
            "runtimeArgs": [
                "run",
                "package:x64"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "Package Linux ARM64",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "/home/kruno/.nvm/versions/node/v22.12.0/bin/npm",
            "runtimeArgs": [
                "run",
                "package:arm64"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "Deploy to RPi",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "/home/kruno/.nvm/versions/node/v22.12.0/bin/npm",
            "runtimeArgs": [
                "run",
                "deploy-to-rpi"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "Fix AppArmor (Unprivileged Userns)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "sudo",
            "runtimeArgs": [
                "sysctl",
                "-w",
                "kernel.apparmor_restrict_unprivileged_userns=0"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Kill Port 5000",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "sudo",
            "runtimeArgs": [
                "fuser",
                "-k",
                "5000/tcp"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Remove Dashberry",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "sudo",
            "runtimeArgs": [
                "apt",
                "remove",
                "-y",
                "dashberry"
            ],
            "console": "integratedTerminal"
        }
    ]
}