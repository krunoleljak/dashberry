{
  "name": "dashberry",
  "version": "1.0.0",
  "description": "Desktop dashboard app",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev:frontend": "cd frontend && npm start",
    "dev:backend": "cd backend && dotnet run",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\" \"npm run dev:electron\"",
    "build:frontend": "cd frontend && npm run build -- --configuration production",
    "build:backend": "cd backend && dotnet publish -c Release",
    "build": "npm run build:frontend && npm run build:backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-log": "^5.4.3",
    "wait-on": "^9.0.4"
  }
}
